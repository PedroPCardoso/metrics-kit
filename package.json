{
  "name": "metrics-monorepo",
  "private": true,
  "description": "Monorepo for nestjs-metrics-core, nestjs-metrics and nextjs-metrics.",
  "license": "MIT",
  "packageManager": "npm@10.8.2",
  "workspaces": [
    "packages/core",
    "packages/cli",
    "packages/nestjs-metrics",
    "packages/nextjs-metrics"
  ],
  "scripts": {
    "build": "turbo run build",
    "typecheck": "turbo run typecheck typecheck:root",
    "typecheck:root": "tsc --noEmit",
    "test": "turbo run test:root --",
    "test:root": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "turbo run test:coverage:root --",
    "test:coverage:root": "vitest run --coverage",
    "coverage:check": "turbo run coverage:check:root",
    "coverage:check:root": "vitest run --coverage",
    "lint": "turbo run lint:root",
    "lint:root": "eslint \"packages/*/src/**/*.ts\" \"test/**/*.ts\"",
    "smoke": "turbo run smoke:root",
    "smoke:root": "bash scripts/consumer-smoke.sh",
    "docs:api": "turbo run docs:api:root",
    "docs:api:root": "typedoc",
    "release": "changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2",
    "@nestjs/common": "^11",
    "@nestjs/core": "^11",
    "@nestjs/testing": "^11",
    "@types/better-sqlite3": "^7",
    "@types/luxon": "^3",
    "@types/node": "^20",
    "@typescript-eslint/eslint-plugin": "^8",
    "@typescript-eslint/parser": "^8",
    "@vitest/coverage-v8": "^2.1.9",
    "better-sqlite3": "^11",
    "drizzle-orm": "^0.36",
    "eslint": "^8",
    "luxon": "^3",
    "mysql2": "^3",
    "pg": "^8",
    "reflect-metadata": "^0.2",
    "tsup": "^8",
    "turbo": "^2.10.3",
    "typedoc": "^0.28",
    "typeorm": "^0.3",
    "typescript": "^6",
    "vitest": "^2"
  }
}
