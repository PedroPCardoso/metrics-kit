{
  "name": "nestjs-metrics",
  "version": "0.4.0",
  "description": "Generate chart-ready metrics and trends from your TypeORM entities in NestJS. Fluent API, locale/timezone-aware bucketing, PostgreSQL/MySQL/SQLite.",
  "keywords": [
    "nestjs",
    "typeorm",
    "metrics",
    "trends",
    "charts",
    "dashboard",
    "analytics",
    "time-series",
    "fluent-api",
    "laravel-metrics",
    "postgresql",
    "mysql",
    "sqlite",
    "typescript"
  ],
  "author": "Pedro Cardoso",
  "license": "MIT",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PedroPCardoso/metrics-kit.git",
    "directory": "packages/nestjs-metrics"
  },
  "homepage": "https://github.com/PedroPCardoso/metrics-kit#readme",
  "bugs": {
    "url": "https://github.com/PedroPCardoso/metrics-kit/issues"
  },
  "type": "commonjs",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./nestjs": {
      "types": "./dist/nestjs/index.d.ts",
      "import": "./dist/nestjs/index.mjs",
      "require": "./dist/nestjs/index.js",
      "default": "./dist/nestjs/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "nestjs",
    "README.md",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "nestjs-metrics-core": "^0.3.0"
  },
  "peerDependencies": {
    "@nestjs/common": "^10 || ^11",
    "typeorm": "^0.3"
  },
  "peerDependenciesMeta": {
    "@nestjs/common": {
      "optional": true
    }
  }
}
