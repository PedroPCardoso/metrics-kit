{
  "name": "nextjs-metrics",
  "version": "0.4.1",
    "description": "Generate chart-ready metrics and trends in Next.js or any Node runtime over Prisma, Drizzle or Kysely. Built on nestjs-metrics-core.",
    "keywords": [
      "nextjs",
      "prisma",
      "drizzle",
      "kysely",
      "metrics",
      "trends",
      "charts",
      "dashboard",
      "analytics",
      "time-series",
      "fluent-api",
      "postgresql",
      "mysql",
      "sqlite",
      "typescript"
    ],
  "author": "Pedro Cardoso",
  "license": "MIT",
  "sideEffects": false,
  "homepage": "https://github.com/PedroPCardoso/metrics-kit#readme",
  "bugs": {
    "url": "https://github.com/PedroPCardoso/metrics-kit/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PedroPCardoso/metrics-kit.git",
    "directory": "packages/nextjs-metrics"
  },
  "type": "commonjs",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./prisma": {
      "types": "./dist/prisma/index.d.ts",
      "import": "./dist/prisma/index.mjs",
      "require": "./dist/prisma/index.js",
      "default": "./dist/prisma/index.js"
    },
    "./drizzle": {
      "types": "./dist/drizzle/index.d.ts",
      "import": "./dist/drizzle/index.mjs",
      "require": "./dist/drizzle/index.js",
      "default": "./dist/drizzle/index.js"
    },
    "./kysely": {
      "types": "./dist/kysely/index.d.ts",
      "import": "./dist/kysely/index.mjs",
      "require": "./dist/kysely/index.js",
      "default": "./dist/kysely/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "prisma",
    "drizzle",
    "kysely",
    "README.md",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "nestjs-metrics-core": "^0.3.1"
  },
  "peerDependencies": {
    "@prisma/client": "*",
    "drizzle-orm": "*",
    "kysely": "*",
    "typeorm": "^0.3"
  },
  "peerDependenciesMeta": {
    "@prisma/client": {
      "optional": true
    },
    "drizzle-orm": {
      "optional": true
    },
    "kysely": {
      "optional": true
    },
    "typeorm": {
      "optional": true
    }
  }
}
