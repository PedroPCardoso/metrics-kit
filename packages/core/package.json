{
  "name": "nestjs-metrics-core",
  "version": "0.4.0",
  "description": "ORM-agnostic metrics & trends engine. Build chart-ready time-series from TypeORM, Prisma, Drizzle or any SQL driver via a fluent API.",
  "keywords": [
    "metrics",
    "trends",
    "charts",
    "dashboard",
    "analytics",
    "sql",
    "fluent-api",
    "typeorm",
    "prisma",
    "drizzle",
    "postgresql",
    "mysql",
    "sqlite",
    "time-series",
    "typescript"
  ],
  "author": "Pedro Cardoso",
  "license": "MIT",
  "sideEffects": false,
  "homepage": "https://github.com/PedroPCardoso/metrics-kit#readme",
  "bugs": {
    "url": "https://github.com/PedroPCardoso/metrics-kit/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PedroPCardoso/metrics-kit.git",
    "directory": "packages/core"
  },
  "type": "commonjs",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./charts": {
      "types": "./dist/charts/index.d.ts",
      "import": "./dist/charts/index.mjs",
      "require": "./dist/charts/index.js",
      "default": "./dist/charts/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "charts",
    "README.md",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "luxon": "^3",
    "zod": "^3"
  },
  "peerDependencies": {
    "typeorm": "^0.3"
  },
  "peerDependenciesMeta": {
    "typeorm": {
      "optional": true
    }
  }
}
